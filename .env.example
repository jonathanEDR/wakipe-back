# ═══════════════════════════════════════════════════════════
#   WAKIPE BACKEND — Variables de entorno
#   Copia este archivo como .env y completa los valores.
#   NUNCA subas .env a Git. Solo .env.example va al repo.
# ═══════════════════════════════════════════════════════════

# ─── Servidor ───────────────────────────────────────────────
# Render asigna PORT automáticamente. No lo definas en Render.
PORT=3000

# ─── MongoDB Atlas ──────────────────────────────────────────
# Crea un cluster gratis en https://cloud.mongodb.com
# Formato: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://USUARIO:PASSWORD@cluster.mongodb.net/wakipe?retryWrites=true&w=majority

# ─── Clerk (Autenticación) ──────────────────────────────────
# Obtén tu SECRET KEY en: https://dashboard.clerk.com → API Keys
# Empieza con sk_test_... (dev) o sk_live_... (prod)
# ¡NUNCA uses la Publishable Key aquí!
CLERK_SECRET_KEY=sk_live_TU_CLAVE_SECRETA

# ─── Cloudinary (Imágenes) ──────────────────────────────────
# Obtén estos datos en: https://console.cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=tu_api_secret

# ─── CORS / Frontend ────────────────────────────────────────
# URL del frontend en producción. Para múltiples orígenes, separa con coma:
#   FRONTEND_URL=https://wakipe.vercel.app,https://wakipe-preview.vercel.app
# En desarrollo local puedes dejarlo vacío (localhost:5173 siempre está permitido).
FRONTEND_URL=https://wakipe.vercel.app
