# Puerto del servidor
PORT=3000

# MongoDB - Conexión a la base de datos
# Opción 1: MongoDB Atlas (producción)
# MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/proinnovate?retryWrites=true&w=majority

# Opción 2: MongoDB Local (desarrollo)
MONGO_URI=mongodb://localhost:27017/proinnovate

# Clerk - Secret Key
# Obtén tu clave desde: https://dashboard.clerk.com/last-active?path=api-keys
# IMPORTANTE: Usa tu SECRET KEY (comienza con sk_test_ o sk_live_), NO la Publishable Key
CLERK_SECRET_KEY=YOUR_CLERK_SECRET_KEY

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:5173
